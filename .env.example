# ── llama.cpp server ─────────────────────────────────────────────────────────

# Path to your GGUF model file relative to the ./models/ directory.
# Example: Qwen2.5-Coder-7B-Instruct-Q5_K_M.gguf
LLAMA_MODEL_PATH=model.gguf

# Optional multimodal projector (required for image input on VLMs).
# Example: mmproj-Qwen2.5-VL-7B-Instruct-f16.gguf
# Leave empty for text-only models.
LLAMA_MMPROJ_PATH=

# Total KV cache size in tokens (split across parallel slots).
# Effective context per slot = LLAMA_CTX_SIZE / LLAMA_PARALLEL
LLAMA_CTX_SIZE=32768

# Number of parallel decode slots (concurrent requests / batching).
LLAMA_PARALLEL=4

# Prompt-processing batch size (tokens per batch). Larger = faster prefill.
LLAMA_BATCH_SIZE=512
LLAMA_UBATCH_SIZE=512

# Quantized KV cache type — q8_0 saves ~50% VRAM vs fp16, negligible quality loss.
# Options: f16, q8_0, q4_0, q4_1, iq4_nl
LLAMA_CACHE_TYPE_K=q8_0
LLAMA_CACHE_TYPE_V=q8_0

# Prefix cache reuse threshold: reuse KV cache when ≥N tokens match the prefix.
LLAMA_CACHE_REUSE=256

# Number of model layers to offload to GPU.
# Set to 0 for CPU-only, 99 to offload all layers (CUDA/Metal).
LLAMA_N_GPU_LAYERS=99

# Host port to expose llama.cpp on (inside Docker it is always 8080).
LLAMA_PORT=8080

# The model name that llama.cpp reports (used in LiteLLM config routing).
# Run `curl http://localhost:8080/v1/models` after starting to find the value.
LLAMA_CHAT_MODEL=local-model

# ── LiteLLM proxy ─────────────────────────────────────────────────────────────

# Master API key — set this to a strong secret in production.
LITELLM_MASTER_KEY=sk-litellm-local

# Port to expose LiteLLM on (inside Docker it is always 4000).
LITELLM_PORT=4000

# Context truncation limit (tokens). Should be < LLAMA_CTX_SIZE.
LITELLM_TRUNCATE_INPUT_TOKENS=30000

# Summarizer fires when estimated tokens exceed this fraction of the truncation limit.
# 0.75 = summarize when at 75% of the limit.
SUMMARIZER_THRESHOLD_RATIO=0.75

# Number of recent turns to keep verbatim (not summarized).
SUMMARIZER_KEEP_RECENT=6

# ── Claude Code ───────────────────────────────────────────────────────────────
# Set by scripts/start-claude.sh; listed here for reference.
# ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_API_KEY=sk-litellm-local
